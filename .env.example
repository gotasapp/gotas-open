# =============================================================
# Gotas Platform - Environment Variables
# =============================================================
# Copy this file to .env.local and fill in the values.
# IMPORTANT: Do NOT use quotes around values in production.
# =============================================================

# --- Database (Required) ---
DATABASE_URL=postgresql://username:password@host:5432/database

# --- Authentication (Required) ---
NEXT_PUBLIC_PRIVY_APP_ID=your-privy-app-id
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# --- Blockchain (Required) ---
# Chiliz Mainnet: 88888 | Testnet: 88882
CHAINID=88888
NEXT_PUBLIC_CHILIZ_RPC_URL=https://rpc.ankr.com/chiliz

# --- Smart Contracts ---
NEXT_PUBLIC_STAKING_CONTRACT=0xYourStakingContractAddress
NEXT_PUBLIC_BURN_STAKING_CONTRACT=0xYourBurnStakingContractAddress
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=0xYourNFTContractAddress
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ADDRESS=0xYourMarketplaceContractAddress

# --- Payment - BRLA (Required for PIX) ---
BRLA_BASE_API_URL=https://api.brla.digital:5567/v1/superuser
BRLA_EMAIL=your-brla-email@example.com
BRLA_PASSWORD=your-brla-password
BRLA_MARKUP_WALLET_ADDRESS=0xYourMarkupWalletAddress
NEXT_PUBLIC_BRLA_MARKUP_WALLET=0xYourMarkupWalletAddress

# --- Storage - AWS S3 (Required for image uploads) ---
STORAGES3_BUCKETNAME=your-bucket-name
STORAGES3_REGION=us-east-1
STORAGES3_ACCESSKEYID=your-access-key-id
STORAGES3_SECRETACCESSKEY=your-secret-access-key

# --- Thirdweb Engine (Optional - disables minting if not configured) ---
THIRDWEB_ENGINE_URL=https://your-engine-instance.engine-usw2.thirdweb.com
THIRDWEB_ENGINE_ACCESS_TOKEN=your-jwt-token
THIRDWEB_ENGINE_BACKEND_WALLET_ADDRESS=0xYourBackendWalletAddress
THIRDWEB_NFT_CONTRACT_ADDRESS=0xYourNFTContractAddress
THIRDWEB_CHAIN_ID=88888
THIRDWEB_CLIENT_ID=your-thirdweb-client-id
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your-thirdweb-client-id

# --- Admin ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-admin-password

# --- Analytics (Optional) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=your-fb-pixel-id

# --- Tracking Pixel (Optional) ---
NEXT_PUBLIC_SLISE_ADV_ID=your-slise-adv-id
NEXT_PUBLIC_SLISE_KEY=your-slise-key
